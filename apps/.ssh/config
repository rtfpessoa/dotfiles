Include ~/.ssh/workspaces/*
Include ~/.orbstack/ssh/config
Include ~/.ssh/1Password/config
Include ~/.colima/ssh_config

# Global defaults
Host *
  # Identity and key handling
  IdentityAgent "~/Library/Group Containers/2BUA8C4S2C.com.1password/t/agent.sock"

  # Prefer modern keys. Keep RSA only if you still need it.
  IdentityFile "~/.ssh/id_ed25519"
  IdentityFile "~/.ssh/id_rsa"

  # macOS specific options, safe to ignore elsewhere
  IgnoreUnknown AddKeysToAgent,UseKeychain
  AddKeysToAgent yes
  UseKeychain yes

  # Host key hygiene
  HashKnownHosts yes
  StrictHostKeyChecking ask
  UserKnownHostsFile "~/.ssh/known_hosts"
  UpdateHostKeys yes

  # DNS SSHFP is nice when it is deployed correctly, but can also be flaky.
  # If you have not set up SSHFP with DNSSEC for your infra, consider turning this off.
  VerifyHostKeyDNS ask

  # Authentication posture
  PubkeyAuthentication yes
  PasswordAuthentication no
  KbdInteractiveAuthentication no
  ChallengeResponseAuthentication no
  PreferredAuthentications publickey

  # Safety defaults
  ForwardAgent no
  ForwardX11 no
  ForwardX11Trusted no
  VisualHostKey no

  # Connection quality
  ServerAliveInterval 60
  ServerAliveCountMax 3
  Compression yes

  # Multiplexing (more secure path than /tmp, avoids collisions, survives reboots sanely)
  ControlMaster auto
  ControlPersist 10m
  ControlPath ~/.ssh/cm/%C

  # Strong algorithm set (OpenSSH will ignore unknown entries gracefully)
  Ciphers chacha20-poly1305@openssh.com,aes256-gcm@openssh.com,aes128-gcm@openssh.com
  MACs hmac-sha2-512-etm@openssh.com,hmac-sha2-256-etm@openssh.com,umac-128-etm@openssh.com
  KexAlgorithms curve25519-sha256,curve25519-sha256@libssh.org
  HostKeyAlgorithms ssh-ed25519-cert-v01@openssh.com,ssh-ed25519

  # Optional: reduce chatty warnings for unknown options on older servers
  LogLevel INFO

# Git hosts
Host github.com gitlab.com
  User git
  ControlMaster no
  ControlPath none

# Localhost should not skip host checks
Host localhost 127.0.0.1 ::1
  VerifyHostKeyDNS no

# "legacy" hosts that require passwords or weaker algos
# Host old-box.example.com
#   PasswordAuthentication yes
#   KbdInteractiveAuthentication yes
#   PreferredAuthentications publickey,password
#   HostKeyAlgorithms +ssh-rsa
